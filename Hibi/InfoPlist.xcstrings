    "NSLocationAlwaysAndWhenInUseUsageDescription": {
      "comment": "Privacy - Location Always and When In Use Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Hibi uses your location to show local weather and sunrise/sunset on each day."
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi 會使用你的位置，在每天顯示當地天氣與日出 / 日落時間。"
          }
        },
        "zh-Hant-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi 會使用你的位置，在每天顯示本地天氣與日出 / 日落時間。"
          }
        },
        "zh-Hans-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi 会使用你的位置，在每天显示本地天气与日出 / 日落时间。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi는 각 날짜의 현지 날씨와 일출/일몰 시간을 표시하기 위해 위치를 사용합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi menggunakan lokasi anda untuk menunjukkan cuaca setempat serta matahari terbit/terbenam pada setiap hari."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi usa tu ubicación para mostrar el tiempo local y la salida/puesta del sol de cada día."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Hibi usa sua localização para mostrar o clima local e o nascer/pôr do sol de cada dia."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi usa la tua posizione per mostrare il meteo locale e alba/tramonto di ogni giorno."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi verwendet deinen Standort, um das lokale Wetter sowie Sonnenauf- und -untergang anzuzeigen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibiは、各日の地域の天気と日の出・日の入り時刻を表示するために位置情報を使用します。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription": {
      "comment": "Shown by iOS when the app requests location while in use.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi verwendet deinen Standort, um das lokale Wetter sowie Sonnenauf- und -untergang anzuzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi uses your location to show local weather and sunrise/sunset on each day."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibiは、各日の地域の天気と日の出・日の入り時刻を表示するために位置情報を使用します。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi 會使用你的位置，在每天顯示當地天氣與日出 / 日落時間。"
          }
        },
        "zh-Hant-HK": {
          "stringUnit": {

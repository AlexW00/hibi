    "NSCalendarsFullAccessUsageDescription": {
      "comment": "Shown by iOS when the app requests full Calendar access.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi möchte auf deinen Kalender zugreifen, um deine Termine anzuzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi would like to access your Calendar so it can display your events."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibiがイベントを表示するために、カレンダーへのアクセスを求めています。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi 想取用你的行事曆，以顯示你的事件。"
          }
        },
        "zh-Hant-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi 想取用你的日曆，以顯示你的事件。"
          }
        },
        "zh-Hans-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi 想访问你的日历，以显示你的事件。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi가 이벤트를 표시하기 위해 캘린더 접근 권한을 요청합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi ingin mengakses Kalendar anda supaya ia boleh memaparkan acara anda."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi quiere acceder a tu calendario para mostrar tus eventos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Hibi gostaria de acessar seu Calendário para exibir seus eventos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hibi vorrebbe accedere al tuo calendario per mostrare i tuoi eventi."
          }
        }
      }
    },

    "Deleting a single occurrence of a recurring event now removes just that one, not the entire series.": {
      "comment": "What's New 1.9 — recurring event deletion fix feature subtitle.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beim Löschen eines einzelnen Termins einer Serie wird jetzt nur noch dieser Termin entfernt; nicht die ganze Serie."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleting a single occurrence of a recurring event now removes just that one, not the entire series."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al eliminar una sola aparición de un evento recurrente, ahora solo se elimina esa; no toda la serie."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminando una singola ricorrenza di un evento ricorrente, ora viene rimossa solo quella; non l'intera serie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "繰り返しイベントの1回分を削除すると、シリーズ全体ではなく、その回だけが削除されるようになりました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",

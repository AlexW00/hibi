    "Switching between Month, Week, and Day now picks up right where you left off.": {
      "comment": "What's New 1.9 — tab position preservation feature subtitle.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beim Wechsel zwischen Monat, Woche und Tag bleibst du jetzt genau dort, wo du aufgehört hast."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Switching between Month, Week, and Day now picks up right where you left off."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al cambiar entre Mes, Semana y Día, ahora se mantiene justo donde lo dejaste."

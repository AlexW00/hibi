            "value" : "Un par de permisos para que Hibi pueda funcionar."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un paio di autorizzazioni per far funzionare Hibi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",

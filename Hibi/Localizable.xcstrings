    "Your reminders now appear alongside calendar events. Tap the checkbox to mark them complete — right from Hibi.": {
      "comment": "What's New 1.8 — reminders feature subtitle.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Erinnerungen erscheinen jetzt neben Kalenderereignissen. Tippe auf das Kästchen, um sie direkt aus Hibi zu erledigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your reminders now appear alongside calendar events. Tap the checkbox to mark them complete - right from Hibi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus recordatorios ahora aparecen junto a los eventos del calendario. Toca la casilla para marcarlos como completados, directamente desde Hibi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi promemoria ora appaiono accanto agli eventi del calendario. Tocca la casella per segnarli come completati - direttamente da Hibi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リマインダーがカレンダーイベントと並んで表示されるようになりました。チェックボックスをタップすれば、Hibi から直接完了にできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미리 알림이 캘린더 이벤트와 함께 표시됩니다. 체크박스를 탭하면 Hibi에서 바로 완료 처리할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Peringatan anda kini muncul bersebelahan acara kalendar. Ketik kotak semak untuk menandakannya selesai - terus dari Hibi."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seus lembretes agora aparecem junto aos eventos do calendário. Toque na caixa para marcá-los como concluídos - direto do Hibi."
          }
        },
        "zh-Hans-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "你的提醒事项现在会与日历事件一起显示。点击复选框即可在 Hibi 中直接完成。"
          }
        },
        "zh-Hant-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "你的提醒事項現在會與日曆事件一同顯示。輕點勾選框即可在 Hibi 中直接完成。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "你的提醒事項現在會與日曆事件一同顯示。輕點勾選框即可在 Hibi 中直接完成。"
          }
        }
      }
    },

    "Prefer swipe-up to go back? Invert the Day-view tear direction in Settings." : {
      "comment" : "What's New 1.1 — invert-swipe-direction feature subtitle.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {

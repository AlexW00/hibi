          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los eventos de varios días ahora aparecen en cada día que cubren, en Mes, Semana y Día."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",

          }
        },
        "zh-Hans-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "跨多天的事件现在会在月、周、日视图中的每个涵盖日期显示。"
          }
        },
        "zh-Hant-HK": {
          "stringUnit": {
            "state": "translated",

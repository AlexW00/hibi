    "The today indicator no longer clips into the row below — the month grid has proper breathing room now.": {
      "comment": "What's New 1.8 — month-grid padding fix feature subtitle.",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Heute-Markierung ragt nicht mehr in die nächste Zeile; die Monatsansicht hat endlich Platz zum Atmen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The today indicator no longer clips into the row below; the month grid has proper breathing room now."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El indicador de hoy ya no se solapa con la fila inferior: la vista de mes tiene espacio para respirar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'indicatore di oggi non sconfina più sulla riga sotto: la vista del mese ora respira meglio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「今日」のインジケーターが下の行に重ならなくなり、月表示にゆとりができました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'오늘' 표시가 더 이상 아래 줄과 겹치지 않으며, 월 보기에 여유 공간이 생겼습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Penunjuk hari ini tidak lagi terhimpit ke baris bawah; paparan bulan kini lebih lapang."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O indicador de hoje não invade mais a linha de baixo; a vista do mês agora respira melhor."
          }
        },
        "zh-Hans-CN": {
          "stringUnit": {
            "state": "translated",
            "value": "「今天」指示圆圈不再与下一行重叠；月视图终于有了合适的留白。"
          }
        },
        "zh-Hant-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "「今天」指示圓圈不再與下一列重疊；月檢視終於有了恰到好處的留白。"
          }
        },
        "zh-Hant-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "「今天」指示圓圈不再與下一列重疊；月檢視終於有了恰到好處的留白。"
          }
        }
      }
    },

.build/

# CocoaPods (uncomment if you add a Podfile)
# Pods/

# Carthage (uncomment if you use Carthage)
# Carthage/Build/

# fastlane / screenshot automation (scripts/screenshots.sh)
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output
# Generated App Store screenshots (regenerate via scripts/screenshots.sh)
screenshots/
# Transparent widget cutouts (regenerate via scripts/remove_widget_backgrounds.py)
screenshots-widgets/
# Third-party helper fetched on demand by scripts/screenshots.sh
HibiUITests/SnapshotHelper.swift

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Accio dependency management (legacy)
Dependencies/
.accio/

# Developer-specific build settings (created by scripts/bootstrap.sh)
Local.xcconfig

# Code Injection / tooling
iOSInjectionProject/
.claude/worktrees

# Raw font sources (selected TTFs are copied into Hibi/Fonts/)
new-fonts/
.codex/config.toml
